{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:import/recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "wp": "readonly",
    "jQuery": "readonly",
    "window": "readonly",
    "document": "readonly",
    "navigator": "readonly",
    "console": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "vendor/",
    "assets/",
    "languages/",
    "tests/e2e/"
  ],
  "rules": {
    "no-console": "off",
    "no-unused-vars": [
      "warn",
      {
        "args": "none",
        "vars": "all"
      }
    ],
    "no-undef": "error",
    "import/no-unresolved": "off"
  }
}
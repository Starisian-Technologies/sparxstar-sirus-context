{
	"servers": {
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "/bin/bash",
			"args": [
				"-c",
				"docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN=\"$GITHUB_PERSONAL_ACCESS_TOKEN\" ghcr.io/github/github-mcp-server:0.21.0"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": ""
			}
		}
	}
}